# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Node / demo UI
node_modules/
.next/
dist-ui/
*.tsbuildinfo

# Data, models, local stores
*.sqlite
*.sqlite3
*.db
.cache/
data/raw/
data/corpus/

# Eval / audit outputs — `audit_log/*` (not `audit_log/`) so the re-include
# below can escape it (git cannot re-include from inside an ignored directory)
eval_results/
audit_log/*
*.log

# Env & secrets
.env
.env.*
!.env.example

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# Local secrets (never commit) — e.g. ANTHROPIC_API_KEY for Layer-E live runs
.env
.env.local

# Per-engagement corpora — kept local, never committed
corpus/engagements/
# EXCEPTION: the EDGAR reference-build Layer-E trend is the public eval record
# (landscape lessons §4 — published trend files are the credibility posture).
!audit_log/layer_e_results.jsonl
